rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required)
    //   - selectedModel: string (optional)
    //   - apiKeys: map (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: topics
    // Document ID: topicId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: chats
    // Document ID: chatId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - title: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: messages
    // Document ID: messageId
    // Fields:
    //   - id: string (required)
    //   - chatId: string (required)
    //   - userId: string (required)
    //   - role: string (required)
    //   - content: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function userIdUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function userIdNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role is string && (data.role == 'admin' || data.role == 'user') &&
             data.createdAt is timestamp &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('selectedModel' in data) || (data.selectedModel is string && data.selectedModel.size() <= 100)) &&
             (!('apiKeys' in data) || data.apiKeys is map) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidTopic(data) {
      return hasRequiredFields(['id', 'userId', 'title', 'content', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidChat(data) {
      return hasRequiredFields(['id', 'userId', 'title', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidMessage(data) {
      return hasRequiredFields(['id', 'chatId', 'userId', 'role', 'content', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.chatId is string && data.chatId.size() > 0 && data.chatId.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.role is string && (data.role == 'user' || data.role == 'model' || data.role == 'system') &&
             data.content is string && data.content.size() >= 0 && data.content.size() < 100000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged() && (request.resource.data.role == 'user' || request.auth.token.email == 'yeswanthvarma94@gmail.com' || request.auth.token.email == 'vinodvarmak2@gmail.com');
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && (request.resource.data.role == resource.data.role || isAdmin() || (request.resource.data.role == 'admin' && (request.auth.token.email == 'yeswanthvarma94@gmail.com' || request.auth.token.email == 'vinodvarmak2@gmail.com')));
      allow delete: if isOwner(userId);
    }

    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidTopic(request.resource.data) && userIdUnchanged();
      allow update: if isAdmin() && isDocOwner() && isValidTopic(request.resource.data) && userIdNotModified();
      allow delete: if isAdmin() && isDocOwner();
    }

    match /chats/{chatId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && userIdUnchanged();
      allow update: if isDocOwner() && isValidChat(request.resource.data) && userIdNotModified();
      allow delete: if isDocOwner();
    }

    match /messages/{messageId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && userIdUnchanged();
      allow update: if isDocOwner() && isValidMessage(request.resource.data) && userIdNotModified();
      allow delete: if isDocOwner();
    }
  }
}
